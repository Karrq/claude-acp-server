{
  "compilerOptions": {
    "target": "ES2021",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2021"],
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": ".",
    "declaration": true,
    "declarationMap": true
  },
  "include": ["src/**/*.ts", "shared/**/*.ts", "openclaw-plugin/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
